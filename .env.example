# Copy this file to .env and fill in the values before deploying.
# .env is gitignored and never committed.

# NVD API key for OWASP Dependency-Check
# Get one for free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-api-key-here

# VNC server password (--vnc profile only)
VNC_PASSWORD=changeme

# PostgreSQL password for SonarQube's internal database (container, loopback only)
SONAR_DB_PASSWORD=changeme

# ---
# SONAR_TOKEN does not belong here — it is generated after the first SonarQube login.
# Save it in .env.ci (also gitignored):
#   echo "SONAR_TOKEN=sqp_..." > .env.ci