# Copie este arquivo para .env e preencha os valores antes do deploy.
# .env é gitignored e nunca commitado.

# Chave da API NVD para o OWASP Dependency-Check
# Obtenha gratuitamente em: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=sua-chave-nvd-aqui

# Senha do servidor VNC (somente perfil --vnc)
VNC_PASSWORD=changeme

# Senha do banco PostgreSQL interno do SonarQube (container, loopback only)
SONAR_DB_PASSWORD=changeme

# ---
# SONAR_TOKEN não fica aqui — ele é gerado após o primeiro login no SonarQube.
# Salve-o em .env.ci (também gitignored):
#   echo "SONAR_TOKEN=sqp_..." > .env.ci
